---
import { site } from '../data/site';
---

<!--
  Two pieces that split during the intro:
   • .brandmark (the logo) settles into the center of the foundation bar
   • .wordmark rises to the top of the page
  live.ts swaps the logo source if a staff member uploads a replacement.
-->
<img class="brandmark" id="brandmark" src="/logo.svg" alt="" aria-hidden="true" />
<h1 class="wordmark" id="wordmark">{site.name}</h1>
