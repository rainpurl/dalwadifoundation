---
import { pillars } from '../data/pillars';
---

<!--
  The skyline. Each column is a CSS 3D prism (four faces in a preserve-3d box).
  stage.ts turns it left/right toward the cursor (--ry) and slides a glare across
  the front (--shine). The text panel sits BEHIND the column and is revealed purely
  by the opaque column sinking past it (true occlusion - no fade). data-p / data-plink
  let live.ts patch copy that staff edit in the portal.
-->
<main class="city" aria-label="The four pillars">
  <div class="towers" id="towers">
    {pillars.map((p, i) => (
      <div class="tower" data-pillar={p.key} data-i={i} style={`--i:${i}`}>
        <div class="tower__panel" id={`panel-${p.key}`} role="group" aria-labelledby={`${p.key}-title`}>
          <h2 class="tp__title" id={`${p.key}-title`} data-p={`${p.key}.title`}>{p.title}</h2>
          <div class="tp__body prose" data-p={`${p.key}.body`}>{p.body}</div>
          <div class="tp__actions">
            <button class="metal metal--dark metal--sm impact-btn" type="button" data-impact-open={p.key} aria-haspopup="dialog">Our impact</button>
            {p.links.map((l, j) => (
              <a
                class="metal metal--sm"
                href={l.href}
                data-plink={`${p.key}.${j}.href`}
                target="_blank"
                rel="noopener noreferrer"
              >
                <span data-plink={`${p.key}.${j}.label`}>{l.label}</span>{!l.ghost && <span class="arr" aria-hidden="true"> →</span>}
              </a>
            ))}
          </div>
        </div>

        <!-- Impact cards for this pillar (hidden data holder; cloned into the impact subpage on open, patched by live.ts) -->
        <div class="tower__impact" data-impact-cards={p.key} hidden>
          {(p.impact || []).map((c) => (
            c.text
              ? <div class="icard icard--text"><p>{c.text}</p></div>
              : <div class="icard"><span class="icard__stat">{c.stat}</span><span class="icard__label">{c.label}</span></div>
          ))}
        </div>

        <button class="tower__btn" type="button" aria-expanded="false" aria-controls={`panel-${p.key}`} aria-label={`${p.name} pillar`}>
          <span class="tower__rise"><span class="tower__bob"><span class="tower__lift"><span class="tower__box">
            <span class="face face--top" aria-hidden="true"></span>
            <span class="face face--left" aria-hidden="true"></span>
            <span class="face face--right" aria-hidden="true"></span>
            <span class="face face--front" aria-hidden="true"><span class="tower__name" data-p={`${p.key}.name`}>{p.name}</span></span>
          </span></span></span></span>
        </button>
      </div>
    ))}
  </div>
</main>
