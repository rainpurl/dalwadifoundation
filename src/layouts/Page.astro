---
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';
import Foundation from '../components/Foundation.astro';
import ZeffyFrame from '../components/ZeffyFrame.astro';
import { site } from '../data/site';
interface Props { title?: string; description?: string; }
const { title = site.name, description = 'The Dalwadi Foundation: art, water, education, and domestic safety.' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0c1a40" />
    <script is:inline>
      (function(){
        // Boot: apply the cached font before first paint (no font flash for return visitors) and
        // start the content request immediately so it overlaps the bundle download. Runs once.
        if (window.__dalwadiBoot) return; window.__dalwadiBoot = true;
        try {
          var c = JSON.parse(localStorage.getItem('dalwadi-content') || 'null');
          if (c && c.settings && c.settings.font && c.settings.font.stack){
            var f = c.settings.font;
            document.documentElement.style.setProperty('--font', f.stack);
            if (f.family){
              var id = 'font-' + f.family.replace(/\s+/g, '-');
              if (!document.getElementById(id)){
                var l = document.createElement('link'); l.id = id; l.rel = 'stylesheet';
                l.href = 'https://fonts.googleapis.com/css2?family=' + f.family.replace(/\s+/g, '+') + ':wght@300;400;500;600;700&display=swap';
                document.head.appendChild(l);
              }
            }
          }
        } catch (e) {}
        try { window.__contentFetch = fetch('/api/content', { cache: 'no-store' }).then(function(r){ return r.ok ? r.json() : null; }); } catch (e) {}
      })();
    </script>
    <script is:inline>
      (function(){
        var el = document.documentElement; el.classList.add('fonts-loading');
        var done = function(){ el.classList.remove('fonts-loading'); };
        try {
          if (document.fonts && document.fonts.load) {
            Promise.race([
              Promise.all([document.fonts.load('600 1em "Cormorant"'), document.fonts.load('300 1em "Cormorant"')]),
              new Promise(function(r){ setTimeout(r, 1500); })
            ]).then(done, done);
          } else { done(); }
        } catch (e) { done(); }
      })();
    </script>
    <script is:inline>
      (function(){
        // Hide sub-page copy on a fresh load until live.ts swaps in the saved content, so
        // the baked defaults don't flash first. Skipped on in-site navigations (the slide
        // covers it); a timeout reveals anyway if the API is slow or never patches.
        if (window.__dalwadiClientNav) return;
        var de = document.documentElement; de.classList.add('content-loading');
        setTimeout(function(){ de.classList.remove('content-loading'); }, 1500);
      })();
    </script>
    <link rel="icon" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
    <!-- Warm the Zeffy donation embed in the background so the Support page opens with little to no load delay -->
    <link rel="preconnect" href="https://www.zeffy.com" />
    <link rel="dns-prefetch" href="https://www.zeffy.com" />
    <link rel="prefetch" href="https://www.zeffy.com/embed/donation-form/d-lanthropy" as="document" />
    <ViewTransitions />
    <script is:inline>
      (function(){
        if (window.__dalwadiNav) return; window.__dalwadiNav = true;
        var order = { '/': 1, '/about': 0, '/contribute': 2 }; // About left, Home center, Support right
        function path(u){ try { return (u && u.pathname) ? u.pathname : new URL(u, location.href).pathname; } catch(e){ return '/'; } }
        function idx(u){ var p = path(u).replace(/\/+$/, ''); if (!p) p = '/'; return (p in order) ? order[p] : 1; }
        var back = false;
        document.addEventListener('astro:before-preparation', function(e){
          window.__dalwadiClientNav = true;
          back = idx(e.to) < idx(e.from);                         // heading toward a page on the left (lower index)
        });
        document.addEventListener('astro:before-swap', function(e){
          // Astro replaces all <html> attributes on swap, so a class set on the current
          // document gets wiped before the slide runs. Set it on the incoming document
          // instead; it survives the swap and is in place when the animation plays.
          if (!e.newDocument || !e.newDocument.documentElement) return;
          e.newDocument.documentElement.classList.toggle('nav-back', back);
          // Navigating in-site to the homepage: skip the splash on the INCOMING document so
          // the navbar and towers are already in their final position in the slide snapshot.
          // Otherwise the snapshot captures .app.is-intro (navbar translated off-screen) and
          // the bar appears to slide away then snap back once stage.ts settles it.
          var app = e.newDocument.getElementById('app');
          if (app && app.classList.contains('is-intro')){
            app.classList.remove('is-intro');
            app.classList.add('no-splash', 'is-settled', 'is-revealed');
          }
        });
      })();
    </script>
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>
    <div class="corner-tr"><slot name="corner-tr" /></div>
    <main class="page" id="main">
      <div class="content"><slot /></div>
    </main>
    <Foundation />
    <ZeffyFrame />
    <script>
      import '../scripts/metal';
      import '../scripts/live';
    </script>
  </body>
</html>
