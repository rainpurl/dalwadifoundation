---
import '../styles/global.css';
import BackButton from '../components/BackButton.astro';
import { site } from '../data/site';
interface Props { title?: string; description?: string; }
const { title = site.name, description = 'The Dalwadi Foundation — art, water, education, and domestic safety.' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0c1a40" />
    <link rel="icon" href="/logo.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Literata:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>
    <header class="topbar">
      <BackButton />
      <a class="topbar__brand" href="/">{site.name}</a>
      <slot name="top-right"><span class="topbar__spacer" aria-hidden="true"></span></slot>
    </header>
    <main class="page" id="main">
      <div class="content"><slot /></div>
    </main>
    <script>
      import '../scripts/metal';
      import '../scripts/live';
    </script>
  </body>
</html>
