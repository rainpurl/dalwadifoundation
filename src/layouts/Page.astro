---
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';
import Foundation from '../components/Foundation.astro';
import { site } from '../data/site';
interface Props { title?: string; description?: string; }
const { title = site.name, description = 'The Dalwadi Foundation: art, water, education, and domestic safety.' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0c1a40" />
    <script is:inline>
      (function(){
        var el = document.documentElement; el.classList.add('fonts-loading');
        var done = function(){ el.classList.remove('fonts-loading'); };
        try {
          if (document.fonts && document.fonts.load) {
            Promise.race([
              Promise.all([document.fonts.load('600 1em "IBM Plex Serif"'), document.fonts.load('300 1em "IBM Plex Serif"')]),
              new Promise(function(r){ setTimeout(r, 1500); })
            ]).then(done, done);
          } else { done(); }
        } catch (e) { done(); }
      })();
    </script>
    <link rel="icon" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Serif:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
    <ViewTransitions />
    <script is:inline>
      (function(){
        if (window.__dalwadiNav) return; window.__dalwadiNav = true;
        var order = { '/': 1, '/about': 0, '/contribute': 2 };
        function path(u){ try { return (u && u.pathname) ? u.pathname : new URL(u, location.href).pathname; } catch(e){ return '/'; } }
        function idx(u){ var p = path(u).replace(/\/+$/, ''); if (!p) p = '/'; return (p in order) ? order[p] : 1; }
        document.addEventListener('astro:before-preparation', function(e){
          window.__dalwadiClientNav = true;
          document.documentElement.classList.toggle('nav-back', idx(e.to) < idx(e.from));
        });
      })();
    </script>
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>
    <div class="corner-tr"><slot name="corner-tr" /></div>
    <main class="page" id="main">
      <div class="content"><slot /></div>
    </main>
    <Foundation transition:name="sitenav" />
    <script>
      import '../scripts/metal';
      import '../scripts/live';
    </script>
  </body>
</html>
