---
import '../styles/global.css';
import { site } from '../data/site';
interface Props { title?: string; description?: string; }
const { title = site.name, description = 'The Dalwadi Foundation — art, water, education, and domestic safety.' } = Astro.props;
const path = Astro.url.pathname.replace(/\/$/, '');
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0c1a40" />
    <link rel="icon" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Literata:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>
    <header class="topbar">
      <a class="topbar__home" href="/" aria-label="Home"><img class="topbar__logo" src="/logo.png" alt="" aria-hidden="true" /><span>{site.name}</span></a>
      <nav class="topnav" aria-label="Primary">
        <a class={'metal metal--sm' + (path === '/about' ? ' is-current' : '')} href="/about">About</a>
        <a class={'metal metal--sm' + (path === '/contribute' ? ' is-current' : '')} href="/contribute">Support</a>
        <slot name="top-right" />
      </nav>
    </header>
    <main class="page" id="main">
      <div class="content"><slot /></div>
    </main>
    <script>
      import '../scripts/metal';
      import '../scripts/live';
    </script>
  </body>
</html>
