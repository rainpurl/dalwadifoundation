---
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'The Dalwadi Foundation',
  description = 'The Dalwadi Foundation supports community and art, water access, education, and domestic safety, backing the organizations doing the work on the ground.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0c1a40" />
    <script is:inline>
      (function(){
        var el = document.documentElement; el.classList.add('fonts-loading');
        var done = function(){ el.classList.remove('fonts-loading'); };
        try {
          if (document.fonts && document.fonts.load) {
            Promise.race([
              Promise.all([document.fonts.load('600 1em "IBM Plex Serif"'), document.fonts.load('300 1em "IBM Plex Serif"')]),
              new Promise(function(r){ setTimeout(r, 1500); })
            ]).then(done, done);
          } else { done(); }
        } catch (e) { done(); }
      })();
    </script>
    <link rel="icon" href="/favicon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Serif:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />

    <ViewTransitions />
    <script is:inline>
      (function(){
        if (window.__dalwadiNav) return; window.__dalwadiNav = true;
        var order = { '/': 1, '/about': 0, '/contribute': 2 }; // About left, Home center, Support right
        function path(u){ try { return (u && u.pathname) ? u.pathname : new URL(u, location.href).pathname; } catch(e){ return '/'; } }
        function idx(u){ var p = path(u).replace(/\/+$/, ''); if (!p) p = '/'; return (p in order) ? order[p] : 1; }
        var back = false;
        document.addEventListener('astro:before-preparation', function(e){
          window.__dalwadiClientNav = true;                       // we are navigating in-site (no splash on home)
          back = idx(e.to) < idx(e.from);                         // heading toward a page on the left (lower index)
        });
        document.addEventListener('astro:before-swap', function(e){
          // Astro replaces all <html> attributes on swap, so a class set on the current
          // document gets wiped before the slide runs. Set it on the incoming document
          // instead; it survives the swap and is in place when the animation plays.
          if (e.newDocument && e.newDocument.documentElement) e.newDocument.documentElement.classList.toggle('nav-back', back);
        });
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
