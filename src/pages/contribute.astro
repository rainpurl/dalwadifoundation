---
import Page from '../layouts/Page.astro';
import { site } from '../data/site';
---
<Page title={`Support · ${site.name}`}>
  <div class="embed-wrap" aria-hidden="true"></div>
</Page>

<style is:global>
  /* The donation form is one persistent iframe, preloaded across the site (ZeffyFrame.astro)
     and shown here via html:has(.embed-wrap), so opening Support has no buffer. This page just
     paints the matching background (#003566) behind the iframe while it fades in. */
  .page:has(.embed-wrap){ padding: 0; min-height: 100svh; background: #003566; }
  .page:has(.embed-wrap) .content{ max-width: none; margin: 0; }
  .embed-wrap{ height: 100svh; background: #003566; }
</style>
