---
import Page from '../layouts/Page.astro';
import { site } from '../data/site';
---
<Page title={`Support · ${site.name}`}>
  <div class="embed-wrap">
    <div class="embed-inner">
      <iframe
        title="Donation form powered by Zeffy"
        src="https://www.zeffy.com/embed/donation-form/d-lanthropy"
        allowpaymentrequest
        allowtransparency="true"
      ></iframe>
    </div>
  </div>
</Page>

<style is:global>
  /* donation embed fills the page above the bottom navbar; the page background matches
     the embed's own background (#003566) so there's no flash while the iframe loads */
  .page:has(.embed-wrap){ padding: 0; min-height: 100svh; background: #003566; }
  .page:has(.embed-wrap) .content{ max-width: none; margin: 0; }
  .embed-wrap{ height: 100svh; box-sizing: border-box; padding-top: 0; padding-bottom: var(--nav-h); background: #003566; }
  .embed-inner{ position: relative; height: 100%; width: 100%; overflow: hidden; background: #003566; }
  .embed-inner iframe{ position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }
</style>
