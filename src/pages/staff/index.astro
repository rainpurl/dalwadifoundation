---
import Base from '../../layouts/Base.astro';
import BackButton from '../../components/BackButton.astro';
import { site } from '../../data/site';
---
<Base title={`Staff · ${site.name}`}>
  <header class="topbar">
    <BackButton />
    <a class="topbar__brand" href="/">{site.name}</a>
    <span class="topbar__spacer" aria-hidden="true"></span>
  </header>

  <main class="portal" id="main">
    <div class="portal__center"><div id="portal-root"></div></div>
    <a class="studio-credit" href="https://katr.es" target="_blank" rel="noopener">built by STUDIO KATRESAI</a>
  </main>

  <div class="sheet-veil" id="sheet-veil"></div>
  <div class="toast" id="toast"></div>

  <style is:global>
    /* The staff portal uses the normal system cursor, not the site's glass cursor.
       This style is only emitted on /staff, so the public pages are unaffected. */
    html{ cursor: auto !important; }
    a, button, summary, [role="button"], .metal, .rt-btn, .gthumb__x{ cursor: pointer !important; }
  </style>

  <script>
    import '../../scripts/portal';
  </script>
</Base>
