---
import Base from '../layouts/Base.astro';
import Towers from '../components/Towers.astro';
import Foundation from '../components/Foundation.astro';
import Brand from '../components/Brand.astro';
---

<Base>
  <a class="skip" href="#towers">Skip to the pillars</a>

  <div class="app is-intro" id="app">
    <!-- Top announcement bar (homepage only); filled by live.ts from settings.announcement, hidden when empty -->
    <a class="announce" id="announce" hidden></a>
    <Towers />
    <Foundation />
    <Brand />

    <!-- phones: tapping a pillar lifts it and shows its info centered here -->
    <div class="pick-veil" id="pick-veil"></div>
    <aside class="pillar-modal" id="pillar-modal" role="dialog" aria-modal="true" aria-hidden="true">
      <button class="pillar-modal__close" type="button" id="pillar-modal-close" aria-label="Close">×</button>
      <div id="pillar-modal-content"></div>
    </aside>

    <!-- Impact subpage: opened from a pillar's "Our impact" button (stage.ts). Title/body/cards
         are filled from that pillar on open; cards are cloned from its .tower__impact holder. -->
    <section class="impact" id="impact" aria-hidden="true" aria-label="Pillar impact">
      <button class="impact__close" type="button" id="impact-close" aria-label="Close impact">×</button>
      <div class="impact__inner">
        <p class="impact__kicker">Our impact</p>
        <h2 class="impact__title" id="impact-title"></h2>
        <p class="impact__body" id="impact-body"></p>
        <div class="impact__cards" id="impact-cards"></div>
      </div>
    </section>
  </div>

  <script>
    import '../scripts/stage';
    import '../scripts/metal';
    import '../scripts/live';
  </script>
</Base>
